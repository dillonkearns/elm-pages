{
    "type": "package",
    "name": "dillonkearns/elm-tui-widgets",
    "summary": "TUI widgets for elm-pages terminal apps.",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "Tui.Layout",
        "Tui.Layout.Effect",
        "Tui.Modal",
        "Tui.Keybinding",
        "Tui.Spinner",
        "Tui.Toast",
        "Tui.FuzzyMatch",
        "Tui.Picker",
        "Tui.CommandPalette",
        "Tui.Search",
        "Tui.Confirm",
        "Tui.OptionsBar",
        "Tui.Status",
        "Tui.Menu",
        "Tui.Prompt",
        "Tui.Layout.Test"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "dillonkearns/elm-pages": "12.2.0 <= v < 13.0.0",
        "elm/core": "1.0.5 <= v < 2.0.0",
        "elm-explorations/test": "2.0.1 <= v < 3.0.0",
        "wolfadex/elm-ansi": "3.0.0 <= v < 4.0.0"
    },
    "test-dependencies": {
    }
