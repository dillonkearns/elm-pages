{
    "type": "package",
    "name": "dillonkearns/elm-tui-widgets",
    "summary": "Layout, modal, and keybinding widgets for elm-pages TUI scripts.",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "Tui.Layout",
        "Tui.Modal",
        "Tui.Keybinding",
        "Tui.Spinner",
        "Tui.Toast",
        "Tui.FuzzyMatch",
        "Tui.Picker",
        "Tui.CommandPalette",
        "Tui.Search",
        "Tui.Confirm",
        "Tui.OptionsBar"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "dillonkearns/elm-pages": "12.0.0 <= v < 13.0.0",
        "elm/core": "1.0.0 <= v < 2.0.0",
        "wolfadex/elm-ansi": "3.0.0 <= v < 4.0.0"
    },
    "test-dependencies": {}
}
