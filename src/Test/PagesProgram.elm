{-| Assert that the rendered view contains elements matching all the given
selectors. The test continues after this assertion - use it inline within
a step list.

    PagesProgram.expect myTest
        [ PagesProgram.ensureViewHas [ Selector.text "Welcome" ]
        , PagesProgram.ensureViewHas [ Selector.id "main-content" ]
        ]

-}
ensureViewHas : List Selector.Selector -> Step model msg
ensureViewHas selectors =
    Internal.Step (ensureViewHasImpl selectors)


ensureViewHasImpl : List Selector.Selector -> ProgramTest model msg -> ProgramTest model msg
ensureViewHasImpl selectors (ProgramTest state) =
    case state.error of
        Just _ ->
            ProgramTest state

        Nothing ->
            case state.phase of
                Resolving (Resolver r) ->
                    ProgramTest
                        { state
                            | error =
                                Just
                                    ("ensureViewHas: Cannot check view while BackendTask data is still resolving. "
                                        ++ "Provide simulated responses first.\n\n"
                                        ++ r.pendingDescription
                                    )
                        }

                Ready ready ->
                    case ready.getModelError ready.model of
                        Just pendingError ->
                            ProgramTest
                                { state
                                    | error =
                                        Just
                                            ("ensureViewHas: " ++ pendingError)
                                }

                        Nothing ->
                            let
                                result : Expectation
                                result =
                                    renderScopedView ready |> Query.has selectors

                                labelList =
                                    SelectorLabel.extractLabels selectors

                                stepLabel =
                                    "ensureViewHas " ++ String.join ", " labelList

                                assertionSels =
                                    List.map SelectorLabel.parseLabelToAssertion labelList
                            in
                            case getFailureMessage result of
                                Just failMsg ->
                                    ProgramTest state
                                        |> recordFailedAssertionSnapshot stepLabel
                                            assertionSels
                                            ("ensureViewHas failed:\n\n" ++ failMsg)

                                Nothing ->
                                    ProgramTest state
                                        |> recordAssertionSnapshot stepLabel assertionSels


