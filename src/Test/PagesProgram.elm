{-| Assert on the current browser URL. Use with framework-driven tests
started with generated `TestApp.start`, where navigation is tracked by the Platform.

    PagesProgram.expect (TestApp.start "/hello" BackendTaskTest.init)
        [ PagesProgram.ensureBrowserUrl
            (\url -> url |> Expect.equal "https://localhost:1234/hello")
        ]

-}
ensureBrowserUrl : (String -> Expectation) -> Step model msg
ensureBrowserUrl assertion =
    Internal.Step (ensureBrowserUrlImpl assertion)


ensureBrowserUrlImpl : (String -> Expectation) -> ProgramTest model msg -> ProgramTest model msg
ensureBrowserUrlImpl assertion (ProgramTest state) =
