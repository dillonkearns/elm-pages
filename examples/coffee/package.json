{
  "name": "elm-pages-coffee-example",
  "version": "1.0.0",
  "description": "Blendhaus coffee shop - elm-pages full-stack demo with declarative server state and a test-first runbook.",
  "scripts": {
    "start": "elm-pages dev",
    "serve": "npm run build && http-server ./dist -a localhost -p 3000 -c-1",
    "build": "elm-pages build --debug --keep-cache",
    "test": "elm-pages test",
    "generate:graphql": "elm-graphql https://loyal-mammal-32.hasura.app/v1/graphql --header \"x-hasura-admin-secret: $HASURA_ADMIN_SECRET\" --output gen"
  },
  "author": "Dillon Kearns",
  "license": "BSD-3",
  "devDependencies": {
    "@dillonkearns/elm-graphql": "^4.3.1",
    "@netlify/functions": "^2.8.2",
    "busboy": "^1.6.0",
    "elm-pages": "file:../..",
    "elm-tooling": "^1.15.1"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3"
  }
}
